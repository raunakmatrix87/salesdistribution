<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="itemConfigDialog"
        title="Variant Configuration"
        contentWidth="72rem"
        contentHeight="36rem"
        draggable="true"
        resizable="true">
        <content>
            <VBox class="sapUiSmallMargin">
                <Title text="{itemConfig>/title}" level="H4" />
                <Text text="{itemConfig>/subtitle}" class="sapUiTinyMarginBottom" />
                <ObjectStatus
                    text="{itemConfig>/progressText}"
                    state="Information"
                    class="sapUiTinyMarginBottom" />
                <Table
                    id="itemConfigTable"
                    inset="false"
                    items="{itemConfig>/rows}">
                    <columns>
                        <Column width="16rem">
                            <header><Label text="Characteristic Name" /></header>
                        </Column>
                        <Column width="16rem">
                            <header><Label text="Selected Value" /></header>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{itemConfig>characteristicName}" />
                                <ComboBox
                                    width="100%"
                                    selectedKey="{itemConfig>selectedValueId}"
                                    selectionChange="onConfigSelectionChange"
                                    items="{itemConfig>options}">
                                    <core:Item
                                        key="{itemConfig>valueId}"
                                        text="{itemConfig>valueName}" />
                                </ComboBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <buttons>
            <Button
                text="Previous"
                enabled="{itemConfig>/canGoPrevious}"
                press="onConfigPrevious" />
            <Button
                text="{itemConfig>/nextButtonText}"
                type="Emphasized"
                press="onConfigNext" />
            <Button text="Cancel" press="onConfigCancel" />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
