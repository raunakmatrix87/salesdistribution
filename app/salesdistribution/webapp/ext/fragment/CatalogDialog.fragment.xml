<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="catalogDialog"
        title="Select Catalog Item"
        contentWidth="90%"
        contentHeight="70%"
        draggable="true"
        resizable="true">
        <content>
            <SearchField
                id="catalogSearch"
                width="100%"
                placeholder="Search catalog"
                liveChange="onCatalogSearch" />
            <Table
                id="catalogTable"
                mode="MultiSelect"
                growing="true"
                growingScrollToLoad="true"
                sticky="ColumnHeaders"
                items="{path: '/catalog'}">
                <columns>
                    <Column><header><Label text="Product" /></header></Column>
                    <Column><header><Label text="Description" /></header></Column>
                    <Column><header><Label text="Category" /></header></Column>
                    <Column><header><Label text="Supplier" /></header></Column>
                    <Column><header><Label text="Price" /></header></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{ProductID}" />
                            <Text text="{ShortDescription}" />
                            <Text text="{Category}" />
                            <Text text="{Supplier}" />
                            <Text text="{Price} {CurrencyCode_code}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <beginButton>
            <Button text="Add" type="Emphasized" press="onCatalogAddConfirm" />
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCatalogCancel" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
